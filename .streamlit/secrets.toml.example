# Copy this file to .streamlit/secrets.toml and fill in your values.
# .streamlit/secrets.toml is git-ignored — never commit real keys.

ANTHROPIC_API_KEY = "sk-ant-..."

# ── Email (shopping list) ──────────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords and paste it below.
SMTP_HOST     = "smtp.gmail.com"
SMTP_PORT     = 587
SMTP_USER     = "you@gmail.com"
SMTP_PASSWORD = "xxxx-xxxx-xxxx-xxxx"   # Gmail app password
DEFAULT_EMAIL = "you@gmail.com"          # Pre-filled recipient in the dialog
